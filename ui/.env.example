# ───────────────────────────────────────────────────────────────────
#  react-frontend — environment variables
#
#  Defaults to demo/mock mode. When REACT_APP_AUTH_MODE is unset or
#  set to "mock", every service (auth, upload, admin, chat) routes
#  to an in-memory implementation. Set it to "cognito" to switch the
#  whole app over to real AWS Cognito + API Gateway + S3 + Bedrock.
#  Backend deployment reference lives in Lambdas.md.
# ───────────────────────────────────────────────────────────────────

# "mock" (default, fully functional demo) or "cognito"
REACT_APP_AUTH_MODE=mock

# ── Required only when REACT_APP_AUTH_MODE=cognito ─────────────────

# API Gateway endpoint (from CDK stack output: APIGatewayUrl)
REACT_APP_API_URL=

# Cognito pool + frontend client (from CDK stack outputs)
REACT_APP_USER_POOL_ID=
REACT_APP_USER_POOL_CLIENT_ID=

# Comma-separated email domain allowlist — enforced by RegisterForm
# and (in cognito mode) by the pre-signup Lambda. Leave empty to allow
# any email (default for the demo).
# Example: REACT_APP_ALLOWED_EMAIL_DOMAINS=@clientdomain.com,@partner.com
REACT_APP_ALLOWED_EMAIL_DOMAINS=
